<?xml version="1.0" ?>
<robot name="bot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find bot_description)/urdf/materials.xacro" />
<xacro:include filename="$(find bot_description)/urdf/bot.trans" />
<xacro:include filename="$(find bot_description)/urdf/bot.gazebo" />
<link name="base_link">
  <inertial>
    <origin xyz="-0.0055277051026628235 -0.01676647852124394 0.04839358995337939" rpy="0 0 0"/>
    <mass value="7.190002859311317"/>
    <inertia ixx="0.054668" iyy="0.070139" izz="0.092571" ixy="-0.0" iyz="-0.0" ixz="0.000211"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find bot_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="red"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="file://$(find bot_description)/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

